generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  clerkId        String           @unique
  email          String?
  name           String?
  imageUrl       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  skinReport     SkinReport?
  physicalReport PhysicalReport?
  mentalReport   MentalReport?
}

model SkinReport {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl        String?
  score           Int
  confidence      Int
  summary         String
  findings        String[]
  recommendations  String[]
  activities      String[]
  metrics         Json
  caution         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PhysicalReport {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl        String?
  score           Int
  confidence      Int
  summary         String
  findings        String[]
  recommendations  String[]
  activities      String[]
  metrics         Json
  caution         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MentalReport {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score           Int
  confidence      Int
  summary         String
  findings        String[]
  recommendations  String[]
  activities      String[]
  metrics         Json
  caution         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
